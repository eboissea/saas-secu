# Server
PORT=3001
NODE_ENV=production

# JWT Secrets (change these in production!)
JWT_SECRET=change-me-to-a-random-64-char-string-in-production
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string

# Admin credentials
ADMIN_USERNAME=admin
# Generate with: node scripts/hash-password.js yourpassword
ADMIN_PASSWORD_HASH=$2a$12$LJ3m4ys3GZfnMRqzMRCBqu/4ULbOHMdSZpsrgv/4CG2lIG.u5YBKS

# CORS
CORS_ORIGIN=http://localhost:5173

# Kubernetes (optional - leave empty if no cluster)
KUBECONFIG_PATH=
